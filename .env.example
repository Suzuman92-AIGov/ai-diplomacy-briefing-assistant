# Local deterministic mode. No model-provider key is required for these defaults.
APP_ENV=local
EMBEDDING_PROVIDER=local
ANSWER_PROVIDER=local
API_BASE_URL=http://localhost:8002

# Optional: set only if your local PostgreSQL configuration differs from docker-compose.yml.
# DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/aidiplomacy

# Optional OpenAI-backed retrieval and briefing.
# OPENAI_API_KEY=<your-api-key>
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Retrieval and event clustering.
DEFAULT_TOP_K=6
EVENT_NEAR_DUPLICATE_TITLE_THRESHOLD=0.92
EVENT_SEMANTIC_SIMILARITY_THRESHOLD=0.78
EVENT_TITLE_MATCH_WINDOW_DAYS=14

# Ingestion limits.
INGESTION_REQUEST_TIMEOUT_SECONDS=30
INGESTION_MAX_DOWNLOAD_BYTES=26214400
INGESTION_MAX_EXTRACTED_TEXT_CHARS=2000000
INGESTION_ERROR_MAX_CHARS=240
